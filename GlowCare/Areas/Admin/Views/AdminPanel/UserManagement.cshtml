@model GlowCare.ViewModels.Users.UserManagementViewModel

@{
    ViewData["Title"] = "Управление на потребители";
    string[] assignableRoleOptions = new[] { "Admin" };
}

<div class="admin-users-page py-5">
    <div class="container">
        <div class="admin-users-header mb-4 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <a asp-area="Admin"
                   asp-controller="AdminPanel"
                   asp-action="Index"
                   class="back-link mb-3 d-inline-flex">
                    <i class="fa fa-arrow-left"></i> Назад
                </a>

                <h1 class="page-title mb-1">Управление на потребители</h1>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success rounded-4 shadow-sm border-0">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger rounded-4 shadow-sm border-0">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (Model.Users == null || !Model.Users.Any())
        {
            <div class="empty-state-card shadow-sm rounded-4">
                <h4 class="mb-2">Няма намерени потребители</h4>
                <p class="text-muted mb-0">В момента няма потребители за управление.</p>
            </div>
        }
        else
        {
            <div class="users-admin-list">
                @foreach (var user in Model.Users)
                {
                    var currentRoles = user.Roles?.ToList() ?? new List<string>();

                    var assignableRoles = assignableRoleOptions
                    .Where(r => !currentRoles.Contains(r))
                    .ToList();

                    var removableRoles = currentRoles.ToList();

                    <article class="user-admin-card">
                        <div class="user-admin-top">
                            <div class="user-admin-profile">
                                <div class="user-admin-avatar">
                                    @(user.FirstName.FirstOrDefault())@(user.LastName.FirstOrDefault())
                                </div>

                                <div>
                                    <h2 class="user-admin-name">@user.FirstName @user.LastName</h2>
                                    <p class="user-admin-email">@user.Email</p>
                                </div>
                            </div>
                        </div>

                        <div class="user-admin-grid">
                            <section class="user-info-box">
                                <p class="user-box-label">Текущи роли</p>

                                @if (currentRoles.Any())
                                {
                                    <div class="user-role-tags">
                                        @foreach (var role in currentRoles)
                                        {
                                            string badgeClass = role == "Admin"
                                            ? "role-badge role-admin"
                                            : role == "Specialist"
                                            ? "role-badge role-specialist"
                                            : "role-badge role-default";

                                            string roleText = role == "Admin"
                                            ? "Админ"
                                            : role == "Specialist"
                                            ? "Специалист"
                                            : role;

                                            <span class="@badgeClass">@roleText</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="role-badge role-default">Няма роли</span>
                                }
                            </section>

                            <section class="user-info-box">
                                <p class="user-box-label">Добавяне на роля</p>

                                <form asp-area="Admin"
                                      asp-controller="AdminPanel"
                                      asp-action="AdminRoleAssign"
                                      method="post"
                                      class="role-form-modern">
                                    <input type="hidden" name="userId" value="@user.Id" />

                                    <select name="roleName"
                                            class="user-select-input"
                                            @(assignableRoles.Any() ? null : "disabled")>
                                        @if (assignableRoles.Any())
                                        {
                                            <option value="">Изберете роля</option>
                                            @foreach (var role in assignableRoles)
                                            {
                                                string roleText = role == "Admin" ? "Админ" : role;
                                                <option value="@role">@roleText</option>
                                            }
                                        }
                                        else
                                        {
                                            <option value="">Няма налични роли</option>
                                        }
                                    </select>

                                    <button type="submit"
                                            class="user-btn user-btn-dark"
                                            @(assignableRoles.Any() ? null : "disabled")>
                                        Добави
                                    </button>
                                </form>
                            </section>

                            <section class="user-info-box">
                                <p class="user-box-label">Премахване на роля</p>

                                <form asp-area="Admin"
                                      asp-controller="AdminPanel"
                                      asp-action="RemoveUserRole"
                                      method="post"
                                      class="role-form-modern">
                                    <input type="hidden" name="userId" value="@user.Id" />

                                    <select name="roleName"
                                            class="user-select-input"
                                            @(removableRoles.Any() ? null : "disabled")>
                                        @if (removableRoles.Any())
                                        {
                                            <option value="">Изберете роля</option>
                                            @foreach (var role in removableRoles)
                                            {
                                                string roleText = role == "Admin"
                                                ? "Админ"
                                                : role == "Specialist"
                                                ? "Специалист"
                                                : role;

                                                <option value="@role">@roleText</option>
                                            }
                                        }
                                        else
                                        {
                                            <option value="">Няма роли за премахване</option>
                                        }
                                    </select>

                                    <button type="submit"
                                            class="user-btn user-btn-outline-danger"
                                            onclick="return confirm('Сигурни ли сте, че искате да премахнете избраната роля от този потребител?');"
                                            @(removableRoles.Any() ? null : "disabled")>
                                        Премахни
                                    </button>
                                </form>
                            </section>

                            <section class="user-info-box danger-box">
                                <p class="user-box-label">Деактивиране</p>

                                <form asp-area="Admin"
                                      asp-controller="AdminPanel"
                                      asp-action="DeleteUser"
                                      method="post"
                                      onsubmit="return confirm('Сигурни ли сте, че искате да деактивирате този потребител?');">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="user-btn user-btn-danger w-100">
                                        <i class="fa fa-user-times me-2"></i>
                                        Деактивирай потребител
                                    </button>
                                </form>
                            </section>
                        </div>
                    </article>
                }
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Навигация по страници" class="mt-5">
                <ul class="pagination justify-content-center custom-pagination mb-0">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link"
                               asp-area="Admin"
                               asp-controller="AdminPanel"
                               asp-action="UserManagement"
                               asp-route-pageNumber="@i">
                                @i
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>