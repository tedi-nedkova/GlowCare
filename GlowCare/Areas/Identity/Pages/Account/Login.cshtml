@page
@model LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="login-main-section">
    <div class="auth-page-under-nav">
        <div class="auth-single-wrap">
            <div class="auth-single-card">
                <div class="auth-heading">
                    <h1 class="auth-title">Добре дошли отново</h1>
                    <div class="auth-title-line"></div>
                </div>

                <form id="account" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="auth-field">
                        <input asp-for="Input.Email"
                               class="form-control auth-input"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="Имейл" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <div class="auth-password-wrap">
                            <input asp-for="Input.Password"
                                   id="passwordInput"
                                   class="form-control auth-input auth-input-password"
                                   autocomplete="current-password"
                                   aria-required="true"
                                   placeholder="Парола" />

                            <button type="button"
                                    id="togglePassword"
                                    class="auth-password-toggle"
                                    aria-label="Покажи паролата"
                                    aria-pressed="false">
                                <i class="fa fa-eye"></i>
                                <span class="auth-password-toggle-text">Покажи</span>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="auth-remember">
                        <label asp-for="Input.RememberMe" class="auth-remember-label">
                            <input class="auth-remember-checkbox" asp-for="Input.RememberMe" />
                            <span id="remember-me-login">@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                        </label>
                    </div>

                    <button id="login-submit" type="submit" class="btn auth-btn">
                        Вход
                    </button>

                    <div class="auth-links">
                        <p>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Създай акаунт</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
