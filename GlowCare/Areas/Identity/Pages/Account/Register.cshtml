@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="login-main-section">
    <div class="auth-page-under-nav">
        <div class="auth-single-wrap">
            <div class="auth-single-card">
                <div class="auth-heading">
                    <h1 class="auth-title">Създай акаунт</h1>
                    <div class="auth-title-line"></div>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="auth-field">
                        <input asp-for="Input.FirstName"
                               class="form-control auth-input"
                               aria-required="true"
                               placeholder="Име" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <input asp-for="Input.LastName"
                               class="form-control auth-input"
                               aria-required="true"
                               placeholder="Фамилия" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <input asp-for="Input.Age"
                               class="form-control auth-input"
                               aria-required="true"
                               placeholder="Възраст" />
                        <span asp-validation-for="Input.Age" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <select asp-for="Input.Gender"
                                class="form-control auth-select"
                                asp-items="Model.GenderOptions">
                            <option value="">Избери пол</option>
                        </select>
                        <span asp-validation-for="Input.Gender" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <input asp-for="Input.Email"
                               class="form-control auth-input"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="Имейл" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <div class="auth-password-wrap">
                            <input asp-for="Input.Password"
                                   id="registerPasswordInput"
                                   class="form-control auth-input auth-input-password"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Парола" />

                            <button type="button"
                                    id="toggleRegisterPassword"
                                    class="auth-password-toggle"
                                    aria-label="Покажи паролата"
                                    aria-pressed="false">
                                <i class="fa fa-eye"></i>
                                <span class="auth-password-toggle-text">Покажи</span>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <div class="auth-password-wrap">
                            <input asp-for="Input.ConfirmPassword"
                                   id="registerConfirmPasswordInput"
                                   class="form-control auth-input auth-input-password"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Потвърди парола" />

                            <button type="button"
                                    id="toggleRegisterConfirmPassword"
                                    class="auth-password-toggle"
                                    aria-label="Покажи паролата"
                                    aria-pressed="false">
                                <i class="fa fa-eye"></i>
                                <span class="auth-password-toggle-text">Покажи</span>
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn auth-btn">
                        Регистрация
                    </button>

                    <div class="auth-links">
                        <p>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" id="reg-already-have-an-account">Вече имаш акаунт? Влез</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
