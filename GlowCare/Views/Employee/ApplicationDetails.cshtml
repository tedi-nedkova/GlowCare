@model GlowCare.ViewModels.SpecialistRequest.SpecialistApplicationViewModel

@{
    ViewData["Title"] = "Application Details";
}

<h2 class="mb-4">Specialist Application Details</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title">Applicant Information</h4>
        <hr />

        <p><strong>Application Id:</strong> @Model.Id</p>
        <p><strong>User Id:</strong> @Model.UserId</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Occupation:</strong> @Model.Occupation</p>
        <p><strong>Experience:</strong> @Model.ExperienceYears years</p>
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Created On:</strong> @Model.CreatedOn.ToString("dd.MM.yyyy HH:mm")</p>

        <p><strong>Biography:</strong></p>
        <div class="border rounded p-3 bg-light">
            @(string.IsNullOrWhiteSpace(Model.Biography) ? "No biography provided." : Model.Biography)
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
        {
            <p class="mt-3"><strong>Rejection Reason:</strong></p>
            <div class="border rounded p-3 bg-light">
                @Model.RejectionReason
            </div>
        }
    </div>
</div>

<div class="d-flex gap-2 mb-4">
    <form asp-area="Admin"
          asp-controller="AdminPanel"
          asp-action="Approve"
          method="post">
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-success">
            Approve Application
        </button>
    </form>

    <a asp-area="Admin"
       asp-controller="AdminPanel"
       asp-action="PendingApplications"
       class="btn btn-secondary">
        Back
    </a>
</div>

<div class="card">
    <div class="card-body">
        <h4 class="card-title text-danger">Decline Application</h4>
        <hr />

        <form asp-area="Admin"
              asp-controller="AdminPanel"
              asp-action="Decline"
              method="post">
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="mb-3">
                <label for="RejectionReason" class="form-label">Rejection Reason</label>
                <textarea name="RejectionReason"
                          id="RejectionReason"
                          class="form-control"
                          rows="5"
                          placeholder="Enter a reason for declining the application..."></textarea>
            </div>

            <button type="submit" class="btn btn-danger">
                Decline Application
            </button>
        </form>
    </div>
</div>