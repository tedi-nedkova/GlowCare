@model GlowCare.ViewModels.SpecialistRequest.ApplySpecialistViewModel

@{
    ViewData["Title"] = "Кандидатстване за специалист";
}



<div class="specialist-apply-page">
    <div class="specialist-apply-wrapper">
        <div class="specialist-apply-header">
            <h1 class="specialist-apply-title">Кандидатстване за специалист</h1>
            <p class="specialist-apply-subtitle">
                Попълни формата по-долу, за да изпратиш заявка за присъединяване като специалист в платформата.
            </p>
        </div>

        @if (TempData["ApplicationErrorMessage"] != null)
        {
            <div class="specialist-status-box error">
                @TempData["ApplicationErrorMessage"]
            </div>
        }

        @if (TempData["ApplicationSuccessMessage"] != null)
        {
            <div class="specialist-status-box success">
                @TempData["ApplicationSuccessMessage"]
            </div>
        }

        @if (ViewBag.ApplicationInfoMessage != null)
        {
            <div class="specialist-status-box info">
                @ViewBag.ApplicationInfoMessage
            </div>
        }

        @if (ViewBag.ApplicationWarningMessage != null)
        {
            <div class="specialist-status-box warning">
                @ViewBag.ApplicationWarningMessage
            </div>

            @if (ViewBag.ApplicationRejectionReason != null)
            {
                <div class="specialist-rejection-box">
                    <p class="specialist-rejection-title">Причина за отхвърляне</p>
                    <p class="specialist-rejection-text">@ViewBag.ApplicationRejectionReason</p>
                </div>
            }
        }

        <div class="specialist-apply-card">
            <div class="specialist-apply-card-header">
                <h2 class="specialist-apply-card-title">Форма за кандидатстване</h2>
                <p class="specialist-apply-card-text">
                    Въведи своята професия, години опит и кратка информация за себе си, за да може заявката ти да бъде разгледана.
                </p>
            </div>

            <div class="specialist-apply-card-body">
                @if (ViewBag.HideApplicationForm != true)
                {
                    <form asp-action="Apply" method="post">
                        <div class="specialist-form-group">
                            <label asp-for="Occupation" class="specialist-form-label">Професия</label>
                            <input asp-for="Occupation"
                                   class="specialist-form-control"
                                   placeholder="Например: дерматолог, козметик, терапевт" />
                            <span asp-validation-for="Occupation" class="specialist-validation"></span>
                        </div>

                        <div class="specialist-form-group">
                            <label asp-for="ExperienceYears" class="specialist-form-label">Години опит</label>
                            <input asp-for="ExperienceYears"
                                   class="specialist-form-control"
                                   placeholder="Например: 5" />
                            <span asp-validation-for="ExperienceYears" class="specialist-validation"></span>
                        </div>

                        <div class="specialist-form-group">
                            <label asp-for="Biography" class="specialist-form-label">Кратка биография</label>
                            <textarea asp-for="Biography"
                                      class="specialist-form-control"
                                      rows="6"
                                      placeholder="Опиши накратко своя опит, квалификация, умения и специализации."></textarea>
                            <span asp-validation-for="Biography" class="specialist-validation"></span>
                        </div>

                        <div class="specialist-form-actions">
                            <button type="submit" class="specialist-btn-primary">
                                Изпрати заявка
                            </button>

                            <a asp-controller="Home" asp-action="Index" class="specialist-btn-secondary">
                                Отказ
                            </a>
                        </div>
                    </form>
                }
                else
                {
                    <div class="specialist-empty-box">
                        В момента не можеш да подадеш нова заявка.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}