@model GlowCare.ViewModels.Employees.EmployeeInfoViewModel

@{
    ViewData["Title"] = "Профил на специалист";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string[] nameParts = Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    string initials = string.Concat(nameParts.Select(part => part[0])).ToUpper();
}



<div class="specialist-details-page">
    <div class="container">
        <div class="specialist-top-back">
            <a asp-area=""
               asp-controller="Employee"
               asp-action="Index"
               class="specialist-secondary-btn">
                <i class="fa fa-arrow-left"></i>
            </a>
        </div>

        <div class="specialist-details-grid">
            <aside class="specialist-side-card">
                <div class="specialist-avatar-large">@initials</div>
                <h1 class="specialist-side-name">@Model.FullName</h1>
                <p class="specialist-side-role">@Model.Occupation</p>

                <div class="specialist-rating-box">
                    @if (Model.ReviewsCount > 0)
                    {
                        var roundedRating = (int)Math.Round(Model.AverageRating, MidpointRounding.AwayFromZero);

                        <div class="specialist-rating-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= roundedRating)
                                {
                                    <span class="rating-star filled">★</span>
                                }
                                else
                                {
                                    <span class="rating-star">★</span>
                                }
                            }
                        </div>

                        <div class="specialist-rating-text">
                            <strong>@Model.AverageRating.ToString("0.0")</strong>
                            <span>(@Model.ReviewsCount ревюта)</span>
                        </div>
                    }
                    else
                    {
                        <div class="specialist-rating-text">
                            Все още няма ревюта за този специалист.
                        </div>
                    }
                </div>

                <div class="specialist-contact-list">
                    <div class="specialist-contact-item">
                        <i class="fa fa-briefcase"></i>
                        <div>
                            <strong>Опит</strong><br />
                            @Model.ExperienceYears години професионален опит
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Email))
                    {
                        <div class="specialist-contact-item">
                            <i class="fa fa-envelope"></i>
                            <div>
                                <strong>Имейл</strong><br />
                                @Model.Email
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                    {
                        <div class="specialist-contact-item">
                            <i class="fa fa-phone"></i>
                            <div>
                                <strong>Телефон</strong><br />
                                @Model.PhoneNumber
                            </div>
                        </div>
                    }
                </div>

                <div class="specialist-side-actions">
                    @if (User.Identity?.IsAuthenticated ?? false && !User.IsInRole("Specialist") && !User.IsInRole("Admin"))
                    {
                        <a asp-controller="Review"
                           asp-action="Add"
                           asp-route-employeeId="@Model.Id"
                           class="specialist-btn">
                            Остави ревю
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity"
                           asp-page="/Account/Login"
                           asp-route-returnUrl="@Url.Action("Add", "Review", new { employeeId = Model.Id })"
                           class="reviews-primary-btn">
                            Остави ревю
                        </a>
                    }

                    <a asp-controller="Review"
                       asp-action="Index"
                       asp-route-employeeId="@Model.Id"
                       class="specialist-secondary-btn review-index-btn">
                        Виж всички ревюта
                    </a>
                </div>
            </aside>

            <section class="specialist-main-card">
                <div class="specialist-section">
                    <h2 class="specialist-section-title">За специалиста</h2>
                    <p class="specialist-section-text">
                        @(string.IsNullOrWhiteSpace(Model.Biography)
                                                ? "Информация за този специалист ще бъде добавена скоро."
                                                : Model.Biography)
                    </p>
                </div>

                <div class="specialist-section">
                    <h2 class="specialist-section-title">Услуги и компетенции</h2>

                    @if (Model.Services.Any())
                    {
                        <div class="specialist-services-list">
                            @foreach (var service in Model.Services)
                            {
                                <span class="specialist-service-chip">@service</span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="specialist-section-text">Все още няма добавени услуги към този профил.</p>
                    }
                </div>


                @if (Model.IsCurrentSpecialistOwner)
                {
                    <div class="specialist-section">
                        <h2 class="specialist-section-title">Записани часове при мен</h2>

                        @if (Model.Procedures.Any())
                        {
                            <div class="table-responsive modern-table-wrap specialist-appointments-wrap">
                                <table class="table modern-table align-middle specialist-appointments-table">
                                    <thead>
                                        <tr>
                                            <th>Процедура</th>
                                            <th>Клиент</th>
                                            <th>Дата</th>
                                            <th>Статус</th>
                                            <th>Действия</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var procedure in Model.Procedures)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="service-name">@procedure.ServiceName</div>
                                                    <div class="service-price">@procedure.Price.ToString("F2") €</div>
                                                </td>
                                                <td>@procedure.ClientName</td>
                                                <td>@procedure.AppointmentDate</td>
                                                <td><span class="modern-badge status-default">@procedure.Status</span></td>
                                                <td>
                                                    @if (procedure.CanBeRejectedBySpecialist)
                                                    {
                                                        <form asp-controller="Procedure" asp-action="Cancel" asp-route-id="@procedure.Id" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="danger-action-btn">Откажи час</button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">—</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="specialist-section-text specialist-empty-state">Все още няма записани часове при този специалист.</p>
                        }
                    </div>
                }

                <div class="specialist-section">
                    <h2 class="specialist-section-title">Работно време</h2>

                    @if (Model.WorkingHours.Any())
                    {
                        <div class="specialist-working-hours-list">
                            @foreach (var slot in Model.WorkingHours)
                            {
                                <div class="specialist-working-hour-row">
                                    <span class="specialist-working-day">@slot.DayOfWeek</span>
                                    <span class="specialist-working-time">@slot.StartTime - @slot.EndTime</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="specialist-section-text">Все още няма добавено работно време за този специалист.</p>
                    }
                </div>
            </section>
        </div>
    </div>
</div>
