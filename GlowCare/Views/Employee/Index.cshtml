@model GlowCare.ViewModels.Employees.EmployeeIndexViewModel

@{
    ViewData["Title"] = "Специалисти";
    Layout = "~/Views/Shared/_Layout.cshtml";

    bool hasEmployees = Model?.Employees?.Any() == true;
    bool hasFilters = !string.IsNullOrWhiteSpace(Model?.SearchTerm) || !string.IsNullOrWhiteSpace(Model?.SelectedService);
}



<div class="specialists-page">
    <div class="container">
        <header class="specialists-hero">
            <h1 class="specialists-title">
                Нашите <span>специалисти</span>
            </h1>
        </header>

        <form method="get" asp-area="" asp-controller="Employee" asp-action="Index" class="specialists-filters">
            <input type="text"
                   name="searchTerm"
                   value="@Model?.SearchTerm"
                   class="specialists-input"
                   placeholder="Търси по име..." />

            <select name="selectedService" class="specialists-select">
                <option value="">Всички услуги</option>

                @if (Model?.AvailableServices != null)
                {
                    @foreach (var service in Model.AvailableServices)
                    {
                        if (string.Equals(Model.SelectedService, service, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@service" selected>@service</option>
                        }
                        else
                        {
                            <option value="@service">@service</option>
                        }
                    }
                }
            </select>

            <button type="submit" class="specialists-filter-btn">
                Търси
            </button>

            <a asp-area="" asp-controller="Employee" asp-action="Index" class="specialists-clear-btn">
                Изчисти
            </a>
        </form>

        @if (hasEmployees)
        {
            <div class="specialists-grid">
                @foreach (var specialist in Model.Employees)
                {
                    string[] nameParts = (specialist.FullName ?? string.Empty)
                    .Split(' ', StringSplitOptions.RemoveEmptyEntries);

                    string initials = nameParts.Any()
                    ? string.Concat(nameParts.Select(part => part[0])).ToUpper()
                    : "?";

                    string shortBiography = string.IsNullOrWhiteSpace(specialist.Biography)
                    ? "Специалист с индивидуален подход и внимание към всеки клиент."
                    : specialist.Biography.Length > 220
                    ? specialist.Biography.Substring(0, 220) + "..."
                    : specialist.Biography;

                    <article class="specialist-card">
                        <div class="specialist-header">
                            <div class="specialist-avatar">@initials</div>

                            <div>
                                <h2 class="specialist-name">@specialist.FullName</h2>
                                <p class="specialist-role">@specialist.Occupation</p>

                                <div class="specialist-meta">
                                    <span class="specialist-meta-item">
                                        <i class="fa fa-briefcase"></i>
                                        @specialist.ExperienceYears години опит
                                    </span>

                                    @if (!string.IsNullOrWhiteSpace(specialist.Email))
                                    {
                                        <span class="specialist-meta-item">
                                            <i class="fa fa-envelope"></i>
                                            @specialist.Email
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <p class="specialist-bio">@shortBiography</p>

                        <div>
                            <h3 class="specialist-section-title">Предлагани услуги</h3>

                            @if (specialist.Services?.Any() == true)
                            {
                                <div class="specialist-tags">
                                    @foreach (var service in specialist.Services.Take(4))
                                    {
                                        <span class="specialist-tag">@service</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="specialist-bio">Информацията за услугите ще бъде добавена скоро.</p>
                            }
                        </div>

                        <div class="specialist-actions">
                            <a asp-area="" asp-controller="Employee" asp-action="Details" asp-route-id="@specialist.Id" class="specialist-btn-outline">
                                Виж профил
                            </a>
                            @if (User.Identity?.IsAuthenticated ?? false && !User.IsInRole("Specialist") && !User.IsInRole("Admin"))
                            {
                                <a asp-controller="Review"
                                   asp-action="Add"
                                   asp-route-employeeId="@specialist.Id"
                                   class="specialist-btn">
                                    Остави ревю
                                </a>
                            }
                            else
                            {
                            <a asp-area="Identity"
                               asp-page="/Account/Login"
                               asp-route-returnUrl="@Url.Action("Add", "Review", new { employeeId = specialist.Id })"
                               class="reviews-primary-btn">
                                Остави ревю
                            </a>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="specialists-empty">
                @if (hasFilters)
                {
                    <p>Няма намерени специалисти по зададените критерии.</p>
                }
                else
                {
                    <p>В момента няма активни специалисти. Моля, проверете отново по-късно.</p>
                }
            </div>
        }
    </div>
</div>