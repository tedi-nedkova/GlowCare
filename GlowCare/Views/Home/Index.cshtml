@using GlowCare.ViewModels.Shared
@model IndexViewModel

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="tm-main-content" id="top">
    <div class="tm-section tm-bg-img" id="tm-section-1">
        <div class="tm-bg-white ie-container-width-fix-2">
            <div class="container ie-h-align-center-fix">
                <div class="row">
                    <div class="col-xs-12 ml-auto mr-auto ie-container-width-fix">
                        @if (TempData["BookingSuccess"] != null)
                        {
                            <div class="alert alert-success">
                                @TempData["BookingSuccess"]
                            </div>
                        }

                        @if (TempData["BookingError"] != null)
                        {
                            <div class="alert alert-danger">
                                @TempData["BookingError"]
                            </div>
                        }

                        <form id="procedureForm" asp-action="Add" asp-controller="Procedure" method="post" class="tm-search-form tm-section-pad-2 booking-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="booking-grid">
                                <div class="booking-item">
                                    <div class="form-group tm-form-element tm-form-element-2">
                                        <select asp-for="EmployeeId"
                                                id="employeeSelect"
                                                class="form-control tm-select"
                                                asp-items="ViewBag.Employees">
                                            <option value="">Специалист</option>
                                        </select>
                                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                                        <i class="fa fa-2x fa-user tm-form-element-icon"></i>
                                    </div>
                                </div>

                                <div class="booking-item">
                                    <div class="form-group tm-form-element tm-form-element-2">
                                        <select asp-for="ServiceId"
                                                id="serviceSelect"
                                                class="form-control tm-select">
                                            <option value="">Процедура</option>
                                        </select>
                                        <span asp-validation-for="ServiceId" class="text-danger"></span>
                                        <i class="fa fa-2x fa-stethoscope tm-form-element-icon"></i>
                                    </div>
                                </div>

                                <div class="booking-item">
                                    <div class="form-group tm-form-element tm-form-element-2">
                                        <i class="fa fa-calendar fa-2x tm-form-element-icon"></i>
                                        <input id="dateInput" type="date" class="form-control" />
                                    </div>
                                </div>

                                <div class="booking-item">
                                    <div class="form-group tm-form-element tm-form-element-2">
                                        <i class="fa fa-2x fa-clock-o tm-form-element-icon"></i>
                                        <input id="timeInput" type="time" class="form-control" />
                                    </div>
                                </div>

                                <div class="booking-item booking-item-full">
                                    <div class="form-group tm-form-element tm-form-element-100 booking-notes-field">
                                        <i class="fa fa-2x fa-pencil tm-form-element-icon"></i>
                                        <textarea asp-for="Notes" class="form-control" placeholder="Бележки"></textarea>
                                        <span asp-validation-for="Notes" class="text-danger"></span>
                                    </div>
                                </div>

                                <input asp-for="AppointmentDate" type="hidden" id="appointmentDateHidden" />

                                <div class="booking-item booking-item-full booking-button-wrap">
                                    <button type="button" id="checkAvailabilityButton" class="btn btn-primary tm-btn-search booking-btn">
                                        ПРОВЕРИ ЗАЕТОСТ
                                    </button>
                                </div>
                            </div>
                        </form>

                        <div id="availabilityModal" style="display:none;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="tm-section-2">
    <div class="container">
        <div class="row">
            <div class="col text-center">
                <h2 class="tm-section-title">Добре дошли в GlowCare!</h2>
                <p class="tm-color-white tm-section-subtitle">Ние сме тук, за да се погрижим за здравето и красотата Ви</p>
            </div>
        </div>
    </div>
</div>

<div class="tm-section tm-position-relative">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none" class="tm-section-down-arrow">
        <polygon fill="#45bb91" points="0,0  100,0  50,60"></polygon>
    </svg>
    <div class="container tm-pt-5 tm-pb-4">
        <div class="row text-center">
            <article class="col-sm-12 col-md-4 col-lg-4 col-xl-4 tm-article">
                <i class="fa tm-fa-6x fa-user-md tm-color-primary tm-margin-b-20"></i>
                <h3 class="tm-color-primary tm-article-title-1">Професионална грижа</h3>
                <p>В GlowCare работим с внимание към всеки пациент и подхождаме индивидуално според нуждите на кожата.</p>
                <a asp-controller="Employee" asp-action="Index" class="text-uppercase tm-color-primary tm-font-semibold">Нашите специалисти</a>
            </article>
            <article class="col-sm-12 col-md-4 col-lg-4 col-xl-4 tm-article">
                <i class="fa tm-fa-6x fa-heartbeat tm-color-primary tm-margin-b-20"></i>
                <h3 class="tm-color-primary tm-article-title-1">Съвременни процедури</h3>
                <p>Предлагаме процедури за почистване, подмладяване, хидратация и грижа при различни кожни състояния.</p>
                <a href="#tm-section-4" class="text-uppercase tm-color-primary tm-font-semibold">Вижте услугите</a>
            </article>
            <article class="col-sm-12 col-md-4 col-lg-4 col-xl-4 tm-article">
                <i class="fa tm-fa-6x fa-star tm-color-primary tm-margin-b-20"></i>
                <h3 class="tm-color-primary tm-article-title-1">Доверие и отзиви</h3>
                <p>Мненията на нашите клиенти са важни за нас и ни помагат постоянно да подобряваме качеството на предлаганите услуги.</p>
                <a asp-controller="Employee" asp-action="Index" class="text-uppercase tm-color-primary tm-font-semibold">Оставете отзиви</a>
            </article>
        </div>
    </div>
</div>


<div class="tm-section tm-section-pad services-section" id="tm-section-4">
    <div class="container">
        <div class="services-shell">
            <div class="services-header text-center">
                <h2 class="services-title">Нашите процедури</h2>
                <p class="services-subtitle">
                    Подбрани терапии и процедури за здрава, свежа и добре поддържана кожа.
                </p>
            </div>

            @if (Model.ServicesInfo != null && Model.ServicesInfo.Any())
            {
                <div class="services-carousel-shell">
                    <div class="tm-services-carousel">
                        @foreach (var service in Model.ServicesInfo)
                        {
                            <div class="service-slide">
                                <article class="service-card-modern">


                                    <h3 class="service-card-name">@service.Name</h3>

                                    <p class="service-card-description">
                                        @(string.IsNullOrWhiteSpace(service.Description)
                                                                        ? "Описание не е добавено за тази услуга."
                                                                        : service.Description)
                            </p>

                                    <div class="service-card-footer">
                                        <div class="service-price-box">
                                            <span class="service-price-label">Цена</span>
                                            <span class="service-price-value">@service.Price.ToString("F2") €</span>
                                        </div>

                                        <a href="#top" class="choose-service-btn service-book-btn">
                                            Запази час
                                        </a>
                                    </div>
                                </article>
                            </div>
                                        }
                    </div>
                </div>
            }
            else
            {
                <div class="services-empty text-center">
                    <p>В момента няма налични услуги.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}