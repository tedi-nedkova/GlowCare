@model GlowCare.ViewModels.Procedures.DeleteProcedureViewModel

@{
    ViewData["Title"] = "Delete Procedure";
}

<h2>Delete Procedure</h2>

<h4>Are you sure you want to delete this procedure?</h4>

<div>
    <p><strong>Client:</strong> @Model.ClientName</p>
    <p><strong>Service:</strong> @Model.ServiceName</p>
</div>

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="ClientName" type="hidden" />
    <input asp-for="ServiceName" type="hidden" />

    <button type="submit">Delete</button>
    <a asp-controller="Procedure" asp-action="MyProcedures">Cancel</a>
</form>