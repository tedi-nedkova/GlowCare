@model GlowCare.ViewModels.Procedures.AvailabilityCheckResultViewModel

<div class="availability-popup">
    @if (Model.IsAvailable)
    {
        <h3 class="availability-title">Часът е свободен</h3>
        <p class="availability-message">@Model.Message</p>

        <div class="availability-actions">
            <button type="button" id="confirmBookButton" class="availability-btn availability-btn-primary">
                Потвърди
            </button>
            <button type="button" id="cancelButton" class="availability-btn availability-btn-secondary">
                Отказ
            </button>
        </div>
    }
    else
    {
        <h3 class="availability-title">Часът не е наличен</h3>
        <p class="availability-message">@Model.Message</p>

        <div class="availability-actions">
            <button type="button" id="cancelButton" class="availability-btn availability-btn-secondary">
                Затвори
            </button>
        </div>
    }
</div>

