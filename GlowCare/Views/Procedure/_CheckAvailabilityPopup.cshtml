@model bool

<div class="availability-popup">
    @if (Model)
    {
    <h3>Часът е свободен!</h3>
    <div class="popup-buttons">
        <button type="button" id="confirmBookButton" class="btn btn-success">Запази</button>
        <button type="button" id="cancelButton" class="btn btn-secondary">Отказ</button>
    </div>
    }
    else
    {
    <h3>Часът вече е зает!</h3>
    <div class="popup-buttons">
        <button type="button" id="cancelButton" class="btn btn-secondary">Отказ</button>
    </div>
    }
</div>

<style>
    #availabilityModal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.45);
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .availability-popup {
        background: white;
        padding: 25px;
        border-radius: 10px;
        text-align: center;
        min-width: 320px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

        .availability-popup h3 {
            margin-bottom: 20px;
        }

    .popup-buttons {
        display: flex;
        justify-content: center;
        gap: 10px;
    }
</style>