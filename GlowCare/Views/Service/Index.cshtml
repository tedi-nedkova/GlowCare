@model GlowCare.ViewModels.Services.ServiceIndexViewModel

@{
    ViewData["Title"] = "Услуги";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}



<div class="services-page">
    <div class="services-header">
        <h1 class="services-title">Нашите <span>услуги</span></h1>
    </div>

    <div class="services-filters">
        <form asp-controller="Service" asp-action="Index" method="get" class="services-filter-form">
            <div class="filter-group">
                <label class="filter-label" for="selectedCategoryId">Категория</label>
                <select id="selectedCategoryId" name="selectedCategoryId" class="filter-control">
                    <option value="">Всички категории</option>
                    @foreach (var category in Model.Categories)
                    {
                        if (Model.SelectedCategoryId.HasValue &&
                        Model.SelectedCategoryId.Value == category.Id)
                        {
                            <option value="@category.Id" selected>@category.Name</option>
                        }
                        else
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="filter-group">
                <label class="filter-label" for="selectedPriceRange">Цена</label>
                <select id="selectedPriceRange" name="selectedPriceRange" class="filter-control">
                    <option value="">Всички цени</option>
                    <option value="under50" selected="@(Model.SelectedPriceRange == "under50")">Под 50</option>
                    <option value="50to100" selected="@(Model.SelectedPriceRange == "50to100")">50 - 100</option>
                    <option value="100to200" selected="@(Model.SelectedPriceRange == "100to200")">100 - 200</option>
                    <option value="200plus" selected="@(Model.SelectedPriceRange == "200plus")">Над 200</option>
                </select>
            </div>

            <div class="filter-group">
                <label class="filter-label" for="selectedAvailabilityRange">Наличност</label>
                <select id="selectedAvailabilityRange" name="selectedAvailabilityRange" class="filter-control">
                    <option value="">По всяко време</option>
                    <option value="today" selected="@(Model.SelectedAvailabilityRange == "today")">Свободно днес</option>
                    <option value="next3days" selected="@(Model.SelectedAvailabilityRange == "next3days")">Свободно до 3 дни</option>
                    <option value="thisWeek" selected="@(Model.SelectedAvailabilityRange == "thisWeek")">Свободно тази седмица</option>
                </select>
            </div>

            <div class="filter-actions">
                <button type="submit" class="filter-btn">Приложи</button>
                <a asp-controller="Service" asp-action="Index" class="filter-btn secondary">Изчисти</a>
            </div>
        </form>
    </div>

    @if (Model.Services.Any())
    {
        <div class="services-grid">
            @foreach (var service in Model.Services)
            {
                <article class="service-card">
                    <div class="service-decorator"></div>

                    <h2 class="service-name">@service.Name</h2>

                    <div class="service-meta">
                        <span class="service-badge">@service.CategoryName</span>
                        <span class="service-badge">@service.DurationInMinutes мин</span>
                    </div>

                    <p class="service-description">
                        @(string.IsNullOrWhiteSpace(service.Description)
                                        ? "Премиум услуга, създадена да ви помогне да се чувствате по най-добрия начин."
                                        : service.Description)
            </p>

                    <div class="service-availability">
                @if (service.EarliestAvailableSlot.HasValue)
                        {
                            <span>Най-ранен свободен час: @service.EarliestAvailableSlot.Value.ToString("dd.MM.yyyy HH:mm")</span>
                        }
                        else
                        {
                            <span>Няма предстояща наличност</span>
                        }
                    </div>

                    <div class="service-card-bottom">
                        <div class="service-price">
                            @service.Price.ToString("0.00")<span>€</span>
                        </div>

                        <a asp-controller="Home" asp-action="Index" class="service-btn">
                            Запази час
                        </a>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="services-empty">
            <h3>Не бяха намерени услуги</h3>
            <p>Опитайте да промените избраната категория, ценовия диапазон или филтъра за наличност.</p>
        </div>
    }

    @if (totalPages > 1)
    {
        <div class="services-pagination">
            <a asp-action="Index"
               asp-route-page="@(currentPage - 1)"
               asp-route-selectedCategoryId="@Model.SelectedCategoryId"
               asp-route-selectedPriceRange="@Model.SelectedPriceRange"
               asp-route-selectedAvailabilityRange="@Model.SelectedAvailabilityRange"
               class="pagination-btn pagination-nav @(currentPage == 1 ? "pagination-disabled" : "")">
                ‹
            </a>

            <div class="pagination-pages">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a asp-action="Index"
                       asp-route-page="@i"
                       asp-route-selectedCategoryId="@Model.SelectedCategoryId"
                       asp-route-selectedPriceRange="@Model.SelectedPriceRange"
                       asp-route-selectedAvailabilityRange="@Model.SelectedAvailabilityRange"
                       class="pagination-btn @(i == currentPage ? "pagination-active" : "")">
                        @i
                    </a>
                }
            </div>

            <a asp-action="Index"
               asp-route-page="@(currentPage + 1)"
               asp-route-selectedCategoryId="@Model.SelectedCategoryId"
               asp-route-selectedPriceRange="@Model.SelectedPriceRange"
               asp-route-selectedAvailabilityRange="@Model.SelectedAvailabilityRange"
               class="pagination-btn pagination-nav @(currentPage == totalPages ? "pagination-disabled" : "")">
                ›
            </a>
        </div>
    }
</div>