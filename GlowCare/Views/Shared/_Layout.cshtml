@using Microsoft.AspNetCore.Identity
@using GlowCare.Entities.Models
@inject UserManager<GlowUser> userManager

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GlowCare</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GlowCare.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/font-awesome/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/slick/slick.css">
    <link rel="stylesheet" href="~/slick/slick-theme.css">
    <link rel="stylesheet" href="~/css/procedureForm.css">
    <link rel="stylesheet" href="~/css/servicesInfoCards.css">
    <link rel="stylesheet" href="~/css/userManagement.css">
    <link rel="stylesheet" href="~/css/auth.css">
    <link rel="stylesheet" href="~/css/datepicker.css">
    <link rel="stylesheet" href="~/css/tooplate-style.css">
    <link rel="stylesheet" href="~/css/serviceIndex.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reviewIndex.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profileIndex.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/employeeIndex.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/procedureCheckAvailabilityPopup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reviewAdd.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/employeeDetails.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/scheduleManagement.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/employeeApply.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/adminUserManagement.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/adminServiceManagement.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/adminReviewsManagement.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/adminPendingApplications.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/adminPanelIndex.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/adminEditService.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/adminAddService.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/adminApplicationDetails.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light">
            <a class="navbar-brand mr-auto" asp-area="" asp-controller="Home" asp-action="Index">
                <img class="img-logo-card" src="~/img/long-logo-bold.png" alt="Site logo">
            </a>

            <button type="button" id="nav-toggle" class="navbar-toggler collapsed"
                    data-toggle="collapse" data-target="#mainNav"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div id="mainNav" class="collapse navbar-collapse tm-bg-white">
                <ul class="navbar-nav ml-auto align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Service" asp-action="Index">Процедури</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Employee" asp-action="Index">Специалисти</a>
                    </li>

                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-area="Admin"
                                   asp-controller="AdminPanel"
                                   asp-action="Index">
                                    Админ панел
                                </a>
                            </li>
                        }

                        @if (!User.IsInRole("Admin") && !User.IsInRole("Specialist"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-area=""
                                   asp-controller="Employee"
                                   asp-action="Apply">
                                    Заявка за специалист
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Profile" asp-action="Index">
                               Моят профил
                            </a>
                        </li>

                        <li class="nav-item">
                            <form method="post"
                                  asp-area="Identity"
                                  asp-page="/Account/Logout"
                                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                                  class="m-0">
                                <button type="submit" class="nav-link logout-link">
                                    ИЗЛЕЗ ОТ ПРОФИЛ
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a asp-area="Identity" asp-page="/Account/Login" class="nav-link">Влез в профил</a>
                        </li>
                        <li class="nav-item">
                            <a asp-area="Identity" asp-page="/Account/Register" class="nav-link">Регистрация</a>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="tm-footer glowcare-footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-left mb-3 mb-md-0">
                    <a class="navbar-brand mr-auto" asp-area="" asp-controller="Home" asp-action="Index">
                        <img class="img-logo-card" src="~/img/long-logo-bold.png" alt="Site logo">
                    </a>
                </div>

                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <p class="glowcare-footer-text mb-1">гр. Казанлък, България</p>
                    <p class="glowcare-footer-text mb-1">+359 88 123 4567</p>
                    <p class="glowcare-footer-text mb-0">contact@glowcare.bg</p>
                </div>

                <div class="col-md-4 text-center text-md-right">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="glowcare-footer-link">Начало</a>
                    <a asp-area="" asp-controller="Employee" asp-action="Index" class="glowcare-footer-link">Специалисти</a>
                    <a href="#tm-section-6" class="glowcare-footer-link">Контакти</a>
                </div>
            </div>

            <hr class="glowcare-footer-divider" />

            <div class="text-center">
                <p class="glowcare-footer-copy mb-0">&copy; 2025 GlowCare | Всички права запазени</p>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/jquery-1.11.3.min.js"></script>
    <script src="~/js/popper.min.js"></script>
    <script src="~/js/bootstrap.min.js"></script>
    <script src="~/js/datepicker.min.js"></script>
    <script src="~/js/jquery.singlePageNav.min.js"></script>
    <script src="~/slick/slick.min.js"></script>
    <script src="~/js/identity-register.js" asp-append-version="true"></script>
    <script src="~/js/identity-login.js" asp-append-version="true"></script>
    <script src="~/js/home-index.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
